{
  "name": "@safestorage/angular",
  "version": "1.0.0",
  "description": "Angular service and module for @safestorage/core — SafeStorageService",
  "keywords": ["localstorage", "encryption", "angular", "service", "secure storage"],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@safestorage/core": "*"
  },
  "peerDependencies": {
    "@angular/core": ">=14.0.0"
  },
  "devDependencies": {
    "@angular/core": "^17.0.0",
    "rxjs": "^7.8.0",
    "zone.js": "^0.14.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
